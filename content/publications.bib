@article{2024privacypolicy,
  selected = {true},
  title = {For whom is privacy policy written? A new understanding of privacy policies},
  author = {With Xiaodong Ding},
  year = {2024},
  journal = {Computer Law \& Security Review},
  volume = {55},
  doi = {10.1016/j.clsr.2024.106072},
  url = {https://doi.org/10.1016/j.clsr.2024.106072},
  langid = {english},
  abstract = {This article reconsiders the audiences and functions of privacy policies under the GDPR and China's Personal Information Protection Law. It argues that privacy policies should support informed choice as well as private and public enforcement by reducing the costs of accessing and understanding legally relevant information.},
