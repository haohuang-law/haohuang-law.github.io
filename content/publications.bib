@unpublished{huang2026wip1,
  title = {China's Digital Constitution},
  author = {Hao Huang},
  journal = {Work in Progress},
  langid = {english},
  abstract = {How should we situate China within global digital regulation? The prevalent theory characterizes Chinese digital regulation as disorderly and unpredictable, and attributes these features to state/party-centered purposes. This Article argues that China has developed unique commitments in digital regulation, including security protection, fairness advancement, trust cultivation, and innovation promotion. These commitments constitute China’s digital constitution, which continuously and stably guides its digital regulation. Under this digital constitution, this Article argues, the dynamics of Chinese digital regulation are better understood as regulatory adaptability created by China’s efforts to navigate among its commitments, rather than as the disorder and unpredictability emphasized by prevailing accounts.}
}

@unpublished{huang2026wip1,
  title = {Detector and Interpreter: Two Roles of Individuals in the Enforcement of Chinese Data},
  author = {Hao Huang},
  journal = {Work in Progress},
  langid = {english},
  abstract = {This Article reconsiders the role of individuals in Chinese data privacy enforcement. Conventional accounts argue that compliance pressure on Chinese companies is generated almost entirely by regulators, while individuals have little impact due to the rarity of private lawsuits and the dominance of regulatory announcements. This Article contends, however, that such a view overlooks how individuals contribute indirectly as detectors of violations and interpreters of vague legal standards. 
Under the Personal Information Protection Law (PIPL), individuals may bring two types of lawsuits—data privacy harm (DPH) and data privacy rights (DPR)—as well as file administrative complaints. These mechanisms rarely impose substantial costs on companies, but they provide regulators and courts with crucial information about noncompliance and generate interpretations of abstract legal requirements. Judicial decisions, complaints, and model cases not only reveal misconduct but also clarify the scope of statutory rights, reduce information costs for companies, and establish focal points for compliance. In this sense, individuals influence regulatory priorities and shape enforcement targets even without directly deterring firms. This unique model reveals Chinese lawmakers’ pragmatic arrangement, because Chinese data privacy regulators lack comparative expertise and Chinese individuals face practical obstacles to collective actions.
This bottom-up enforcement model has broader significance. By situating the Chinese case in comparative debates, it explores three important data privacy questions: geopolitics of data privacy regulation, conceptualization of data privacy, functions of data privacy private enforcement.
}
}
